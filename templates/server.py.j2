            handlers.append(handler)
        if handlers:
            for handler in handlers:
                handler.inject(headers, qparams, cookies)
            auth_applied = True
            break
    if not auth_applied:
        return {
            "error": "auth_unavailable",
            "message": "Required authentication credentials are not configured for this operation.",
