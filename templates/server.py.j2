    auth_map = _auth.build_auth_registry()
    op_schemes = _auth.OPERATION_AUTH_MAP.get({{ operation.operation_id | pystr }}, [])
    auth_applied = not op_schemes
    for scheme_group in op_schemes:
        handlers = []
        for scheme_name in scheme_group:
            handler = auth_map.get(scheme_name)
            if not (handler and handler.is_available()):
                handlers = []
