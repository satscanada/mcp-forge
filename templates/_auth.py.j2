# Auth registry — keyed by scheme name
# ════════════════════════════════════════════════════
def build_auth_registry() -> dict:
    """Build auth handlers from environment. Missing creds = scheme disabled."""
    registry: dict[str, object] = {}
{% for scheme in scheme_contexts %}
    try:
        registry[{{ scheme.name | pystr }}] = {{ scheme.class_name }}(
{% for arg in scheme.registry_args %}
            {{ arg.name }}={{ arg.value | pystr }},
{% endfor %}
        )
    except ValueError as e:
        logger.warning("Auth setup for %s: %s", {{ scheme.name | pystr }}, e)
{% endfor %}
    return registry
