{% if "OAuth2ClientCredentialsAuth" in class_names %}
class OAuth2ClientCredentialsAuth:
    """OAuth2 client credentials flow with lazy token fetch and refresh."""
    def __init__(
        self,
        client_id_env: str = "OAUTH_CLIENT_ID",
        client_secret_env: str = "OAUTH_CLIENT_SECRET",
        token_url_env: str = "OAUTH_TOKEN_URL",
        scopes_env: str = "OAUTH_SCOPES",
        default_token_url: str = "",
        default_scopes: str = "",
    ):
        self.client_id = os.getenv(client_id_env, "").strip()
        self.client_secret = os.getenv(client_secret_env, "").strip()
        self.token_url = os.getenv(token_url_env, default_token_url).strip()
        self.scopes = os.getenv(scopes_env, default_scopes).strip()
        self._access_token = ""
        self._expires_at = 0.0
        if not self.client_id or not self.client_secret or not self.token_url:
            raise ValueError(
                f"OAuth2 client credentials env vars missing for {client_id_env}/{client_secret_env}/{token_url_env}. "
                "Set them in .env to enable OAuth2 client credentials auth."
            )

    def _fetch_token(self) -> None:
        payload = {"grant_type": "client_credentials"}
        if self.scopes:
            payload["scope"] = self.scopes
        data = urllib.parse.urlencode(payload).encode("utf-8")
        credentials = f"{self.client_id}:{self.client_secret}".encode("utf-8")
        auth_header = base64.b64encode(credentials).decode("ascii")
        request = urllib.request.Request(
            self.token_url,
            data=data,
            headers={
                "Content-Type": "application/x-www-form-urlencoded",
                "Authorization": f"Basic {auth_header}",
                "Accept": "application/json",
            },
            method="POST",
        )
        try:
            with urllib.request.urlopen(request, timeout=15) as response:
                payload = json.loads(response.read().decode("utf-8"))
        except urllib.error.URLError as exc:
            raise ValueError(f"OAuth2 token fetch failed: {exc}") from exc

        token = (payload.get("access_token") or "").strip()
        if not token:
            raise ValueError("OAuth2 token response did not include access_token")
        expires_in = int(payload.get("expires_in", 3600) or 3600)
        self._access_token = token
        self._expires_at = time.time() + max(expires_in - 30, 30)

    def inject(self, headers: dict, params: dict, cookies: dict) -> None:
        if not self._access_token or time.time() >= self._expires_at:
            self._fetch_token()
        headers["Authorization"] = f"Bearer {self._access_token}"

    def is_available(self) -> bool:
        return bool(self.client_id and self.client_secret and self.token_url)

