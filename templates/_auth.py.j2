{% if "BasicAuth" in class_names %}
class BasicAuth:
    """HTTP Basic authentication using username/password from the environment."""
    def __init__(self, username_env: str = "BASIC_AUTH_USERNAME", password_env: str = "BASIC_AUTH_PASSWORD"):
        self.username = os.getenv(username_env, "").strip()
        self.password = os.getenv(password_env, "").strip()
        if not self.username or not self.password:
            raise ValueError(
                f"{username_env}/{password_env} environment variables not set. "
                "Set them in .env to enable HTTP Basic auth."
            )

    def inject(self, headers: dict, params: dict, cookies: dict) -> None:
        raw = f"{self.username}:{self.password}".encode("utf-8")
        headers["Authorization"] = "Basic " + base64.b64encode(raw).decode("ascii")

    def is_available(self) -> bool:
        return bool(self.username and self.password)

