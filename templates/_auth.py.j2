{% if "BearerTokenAuth" in class_names %}
class BearerTokenAuth:
    """HTTP Bearer authentication using a static token from the environment."""
    def __init__(self, env_var: str = "BEARER_TOKEN"):
        self.env_var = env_var
        self.token = os.getenv(env_var, "").strip()
        if not self.token:
            raise ValueError(
                f"{env_var} environment variable not set. "
                "Set it in .env to enable Bearer auth."
            )

    def inject(self, headers: dict, params: dict, cookies: dict) -> None:
        headers["Authorization"] = f"Bearer {self.token}"

    def is_available(self) -> bool:
        return bool(self.token)

