{% if "MTLSAuth" in class_names %}
class MTLSAuth:
    """Mutual TLS (mTLS) authentication — loads a client certificate onto the httpx SSL context.

    Unlike header-based auth, mTLS is transport-level. This class exposes
    ``get_ssl_kwargs()`` which is consumed by ``get_client()`` in server.py
    to configure the httpx.AsyncClient with the appropriate SSL context.
    """

    def __init__(
        self,
        cert_env: str = "MTLS_CERT_PATH",
        key_env: str = "MTLS_KEY_PATH",
        ca_env: str = "MTLS_CA_PATH",
    ):
        self.cert_path = os.getenv(cert_env, "").strip()
        self.key_path = os.getenv(key_env, "").strip()
        self.ca_path = os.getenv(ca_env, "").strip()
        if not self.cert_path or not self.key_path:
            raise ValueError(
                f"{cert_env}/{key_env} environment variables not set. "
                "Set them in .env to enable mTLS auth."
            )

    def inject(self, headers: dict, params: dict, cookies: dict) -> None:
        """No-op: mTLS is transport-level — per-request header injection is not required."""

    def get_ssl_kwargs(self) -> dict:
        """Return keyword arguments suitable for httpx.AsyncClient(**kwargs)."""
        import ssl

        ctx = ssl.create_default_context(
            purpose=ssl.Purpose.SERVER_AUTH,
            cafile=self.ca_path or None,
        )
        ctx.load_cert_chain(certfile=self.cert_path, keyfile=self.key_path or None)
        return {"verify": ctx}

    def is_available(self) -> bool:
        return bool(self.cert_path and self.key_path)

